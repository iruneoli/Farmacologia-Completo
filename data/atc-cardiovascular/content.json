{
  "atc": "cardiovascular",
  "nombre": "ATC Cardiovascular",
  "descripcion": "Sistema cardiovascular",
  "codigos": [
    {
      "codigo": "C01",
      "nombre": "Terapia cardíaca",
      "descripcion": "Asistencia médica y paramédica al paciente con cardiopatía, especialmente después de una crisis cardiovascular como infarto de miocardio, angioplastia o cirugía cardíaca."
    },
    {
      "codigo": "C02",
      "nombre": "Antihipertensivos",
      "descripcion": "Actúan contra el incremento continuo de la fuerza ejercida por la sangre sobre las paredes de los vasos sanguíneos. La hipertensión se asocia a mayor riesgo de aterosclerosis."
    },
    {
      "codigo": "C03",
      "nombre": "Diuréticos",
      "descripcion": "Provocan eliminación de agua y electrolitos del organismo a través de la orina y la expulsión de materia fecal."
    },
    {
      "codigo": "C04",
      "nombre": "Vasodilatadores periféricos",
      "descripcion": "Dilatan o relajan los vasos sanguíneos, disminuyen la resistencia, reducen la presión arterial y facilitan el flujo de sangre."
    },
    {
      "codigo": "C05",
      "nombre": "Vasoprotectores",
      "descripcion": "Mejoran la fragilidad, permeabilidad y resistencia de los vasos."
    },
    {
      "codigo": "C07",
      "nombre": "Agentes beta-bloqueantes",
      "descripcion": "Se usan en insuficiencia cardiaca, especialmente tras infarto, y en arritmias. Bloquean receptores de mediadores adrenérgicos como la adrenalina, reduciendo la contracción cardíaca, frecuencia cardíaca y producción de renina."
    },
    {
      "codigo": "C08",
      "nombre": "Bloqueantes de canales de calcio",
      "descripcion": "Reducen el paso del calcio al músculo cardíaco y a los vasos sanguíneos, relajando los vasos y reduciendo la presión arterial. Se usan en hipertensión, angina de pecho y arritmias."
    },
    {
      "codigo": "C09",
      "nombre": "Agentes que actúan sobre el sistema renina-angiotensina",
      "descripcion": "Actúan sobre el sistema hormonal que regula a largo plazo la presión sanguínea y el volumen extracelular corporal."
    },
    {
      "codigo": "C10",
      "nombre": "Agentes que reducen los lípidos séricos",
      "descripcion": "Hipolipemiantes que reducen los niveles de colesterol y triglicéridos."
    }
  ],
