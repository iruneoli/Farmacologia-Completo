  "bloquesTeoricos": [
    {
      "titulo": "Definición de antibiótico",
      "contenido": "Un antibiótico es una sustancia secretada por un microorganismo, aunque hoy también existen antibióticos sintéticos, con capacidad para matar o impedir el crecimiento de microorganismos."
    },
    {
      "titulo": "Toxicidad selectiva",
      "contenido": "Los antibióticos presentan toxicidad selectiva, siendo superior para los organismos invasores que para los animales o seres humanos que los hospedan."
    },
    {
      "titulo": "Bacteriostático y bactericida",
      "contenido": "Un antibiótico es bacteriostático si impide el crecimiento de los gérmenes y bactericida si los destruye."
    },
    {
      "titulo": "Automedicación y resistencias",
      "contenido": "La automedicación con antibióticos puede generar bacterias resistentes por elección inadecuada del antibiótico o posología incorrecta."
    },
    {
      "titulo": "Uso frente a virus",
      "contenido": "Los antibióticos y antimicrobianos son inefectivos frente a enfermedades virales."
    }
  ],
  "criterios": [
    {
      "criterio": "Mecanismos de acción",
      "tipos": [
        {
          "nombre": "Inhibidores de la síntesis de la pared bacteriana",
          "indicacion": "Destruyen o impiden la formación de la pared bacteriana y por tanto las bacterias mueren."
        },
        {
          "nombre": "Inhibidores de la síntesis proteica",
          "indicacion": "Actúan sobre los ribosomas bacterianos."
        },
        {
          "nombre": "Inhibidores de la síntesis o actividad de los ácidos nucleicos",
          "indicacion": "Inhiben enzimas bacterianas que transcriben ADN a ARN o duplican el ADN."
        },
        {
          "nombre": "Que actúan sobre la membrana plasmática",
          "indicacion": "Disuelven la membrana produciendo la muerte del hongo."
        }
      ]
    },
    {
      "criterio": "Efecto sobre los microorganismos",
      "tipos": [
        {
          "nombre": "Bactericidas",
          "indicacion": "Matan bacterias."
        },
        {
          "nombre": "Bacteriostáticos",
          "indicacion": "Detienen el crecimiento y la proliferación."
        }
      ]
    },
    {
      "criterio": "Espectro de actuación",
      "tipos": [
        {
          "nombre": "Amplio espectro",
          "indicacion": "Actúan sobre la mayoría de los microorganismos."
        },
        {
          "nombre": "Selectivos",
          "indicacion": "Solo son activos frente a unas bacterias determinadas."
        }
      ]
    }
